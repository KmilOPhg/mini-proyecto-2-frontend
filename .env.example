# API REST (backend) — incluir /api
VITE_API_URL=http://localhost:1206/api

# Chat en tiempo real (socket server)
VITE_SOCKET_URL=http://localhost:3001

# Signaling WebRTC (PeerJS + socket.io de salas AV)
VITE_WEBRTC_URL=http://localhost:3002

# Firebase (cliente web — valores públicos de Firebase Console)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Dominios de correo institucional (coma-separados). Vacío = edu.co por defecto.
VITE_INSTITUTIONAL_EMAIL_DOMAINS=edu.co

